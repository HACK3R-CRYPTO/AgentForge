# ============================================
# AgentForge Environment Variables
# ============================================

# Stellar Network
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# Orchestrator wallet (signs Soroban contract calls)
ORCHESTRATOR_PUBLIC_KEY=G...
ORCHESTRATOR_SECRET_KEY=S...

# Platform wallet (signs x402 micropayments — must NOT be the USDC issuer)
PLATFORM_PUBLIC_KEY=G...
PLATFORM_SECRET_KEY=S...

# Agent wallets (receive x402 payments)
SCRAPER_PUBLIC_KEY=G...
SCRAPER_SECRET_KEY=S...
SUMMARIZER_PUBLIC_KEY=G...
SUMMARIZER_SECRET_KEY=S...
ANALYST_PUBLIC_KEY=G...
ANALYST_SECRET_KEY=S...

# x402 Facilitator wallet (settles payments on Stellar)
FACILITATOR_PUBLIC_KEY=G...
FACILITATOR_SECRET_KEY=S...
FACILITATOR_PORT=4022

# Soroban Contract IDs (set after deployment — see packages/contracts/README.md)
SERVICE_REGISTRY_CONTRACT_ID=C...
SPENDING_POLICY_CONTRACT_ID=C...

# USDC on Stellar Testnet
# Use a custom SAC if you are the USDC issuer, or Circle testnet USDC otherwise:
# USDC_CONTRACT_ID=CBIELTK6YBZJU5UP2WWQEUCYKLPU6AUNZ2BQ4WWFEIE3USCIHMXQDAMA
USDC_CONTRACT_ID=C...

# Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Server
PORT=4021
FRONTEND_URL=http://localhost:3000

# Set to "true" to run without real AI or payments (frontend dev only)
MOCK_MODE=false
